# Backend API base URL used by the browser for /api calls.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal backend URL used by Next server route /uploads/* proxy (Docker service name).
# BACKEND_INTERNAL_URL=http://backend:3001

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here

# Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Base URL (for SEO and canonicals)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Deployment Environment
DEPLOYMENT_ENV=local
DOMAIN=localhost

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_COMPARISON=true
